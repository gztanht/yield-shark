# 🦈 YieldShark 环境配置示例
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# API 密钥 (可选)
# DEFI_PULSE_API_KEY=your_api_key_here
# COINGECKO_API_KEY=your_api_key_here

# 钱包地址 (用于 Gas 费估算)
# WALLET_ADDRESS=0xYourWalletAddress

# 通知设置 (可选)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# 调试模式
DEBUG=false

# 请求速率限制 (次/分钟)
RATE_LIMIT=60
